  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:edit": "vite build --config vite.config.edit.ts",
    "build:admin": "vite build --config vite.config.admin.ts",
    "build:derived-edit": "vite build --config vite.config.derived-edit.ts",
    "build:ci": "npm run build:edit && npm run build:admin && npm run build:derived-edit",
    "build": "npm run typecheck && npm run build:ci"
  },
