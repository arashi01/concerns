{
  "name": "concerns",
  "license": "MIT",
  "author": "arashi01",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/build.mjs",
    "forge:prepare": "npm run build && node scripts/forge-prepare.mjs",
    "forge:deploy": "npm run forge:prepare && cd forge-build && forge deploy -e production --non-interactive",
    "forge:deploy:dev": "npm run forge:prepare && cd forge-build && forge deploy -e development --non-interactive",
    "forge:tunnel": "npm run forge:prepare && cd forge-build && forge tunnel"
  },
  "dependencies": {
    "@atlaskit/breadcrumbs": "^15.3.21",
    "@atlaskit/button": "^23.10.3",
    "@atlaskit/code": "^17.4.3",
    "@atlaskit/css": "^0.19.2",
    "@atlaskit/css-reset": "^7.3.13",
    "@atlaskit/dynamic-table": "^18.3.21",
    "@atlaskit/flag": "^17.8.9",
    "@atlaskit/heading": "^5.3.0",
    "@atlaskit/lozenge": "^13.5.2",
    "@atlaskit/modal-dialog": "^14.11.5",
    "@atlaskit/primitives": "^18.0.2",
    "@atlaskit/section-message": "^8.12.8",
    "@atlaskit/select": "^21.8.2",
    "@atlaskit/spinner": "^19.0.11",
    "@atlaskit/tabs": "^18.3.5",
    "@atlaskit/tag": "^14.5.4",
    "@atlaskit/tag-group": "^12.0.4",
    "@atlaskit/textarea": "^8.2.4",
    "@atlaskit/textfield": "^8.2.3",
    "@atlaskit/tokens": "^11.1.1",
    "@forge/api": "^7.1.2",
    "@forge/bridge": "5.15.0",
    "@forge/kvs": "^1.6.0",
    "@forge/react": "11.14.0",
    "@forge/resolver": "^1.7.1",
    "@types/papaparse": "^5.5.2",
    "neverthrow": "^8.2.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@compiled/babel-plugin": "^0.39.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
