#!/bin/bash

# Merge the devel branch into main and push to trigger a production deploy.
#
# CI handles the actual Forge deployment and GitHub release creation on push
# to main. This script ensures the local state is clean and up-to-date before
# performing a fast-forward merge.

set -euo pipefail

# --- Configuration ---
: "${MAIN_REPO_OWNER:=arashi01}"
: "${MAIN_REPO_NAME:=concerns}"

readonly DEVEL_BRANCH="devel"
readonly MAIN_BRANCH="main"

# Define colours for output
readonly C_RESET='\033[0m'
readonly C_RED='\033[0;31m'
readonly C_GREEN='\033[0;32m'
readonly C_YELLOW='\033[0;33m'

# --- Helper Functions ---

error() {
  echo -e "${C_RED}Error: $1${C_RESET}" >&2
  exit 1
}

success() {
  echo -e "${C_GREEN}$1${C_RESET}"
}

info() {
  echo -e "${C_YELLOW}$1${C_RESET}"
}

show_help() {
  echo "Usage: $(basename "$0")"
  echo
  echo "Merges the devel branch into main and pushes to trigger a production"
  echo "deploy via CI. Must be run from the devel branch with a clean working"
  echo "directory that is up-to-date with the main repository remote."
  echo
  echo "Main repository settings:"
  echo "  MAIN_REPO_OWNER=${MAIN_REPO_OWNER}"
  echo "  MAIN_REPO_NAME=${MAIN_REPO_NAME}"
  echo
  echo "Options:"
  echo "  -h, --help    Show this help message and exit"
}

# --- Main Script Logic ---

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_help
  exit 0
fi

# Ensure clean working directory
if [ -n "$(git status --porcelain)" ]; then
  info "There are uncommitted changes in the working directory:"
  git status
  error "Please commit or stash your changes before releasing."
fi

# Ensure we are on the devel branch
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$current_branch" != "$DEVEL_BRANCH" ]]; then
  error "Must be on '$DEVEL_BRANCH' branch to release. Currently on '$current_branch'."
fi

# Locate the remote that points to the main repository (HTTPS or SSH)
MAIN_REPO_HTTPS="https://github.com/${MAIN_REPO_OWNER}/${MAIN_REPO_NAME}"
MAIN_REPO_HTTPS_GIT="${MAIN_REPO_HTTPS}.git"
MAIN_REPO_SSH="git@github.com:${MAIN_REPO_OWNER}/${MAIN_REPO_NAME}.git"
MAIN_REMOTE=""
for r in $(git remote); do
  urls=$(git remote get-url --all "$r" 2>/dev/null || true)
  if echo "$urls" | grep -qxF "$MAIN_REPO_HTTPS" || \
     echo "$urls" | grep -qxF "$MAIN_REPO_HTTPS_GIT" || \
     echo "$urls" | grep -qxF "$MAIN_REPO_SSH"; then
    MAIN_REMOTE="$r"
    break
  fi
done

if [ -z "$MAIN_REMOTE" ]; then
  error "No git remote points to ${MAIN_REPO_OWNER}/${MAIN_REPO_NAME}. Add one and try again."
fi

# Fetch latest state from the main repository
info "Fetching from '$MAIN_REMOTE'..."
git fetch "$MAIN_REMOTE" >/dev/null 2>&1

# Ensure devel is up-to-date with its upstream
if git rev-parse --verify --quiet "${MAIN_REMOTE}/${DEVEL_BRANCH}" >/dev/null 2>&1; then
  ahead=0; behind=0
  IFS=$'\t ' read -r ahead behind <<< "$(git rev-list --left-right --count HEAD..."${MAIN_REMOTE}/${DEVEL_BRANCH}")"
  if (( behind > 0 )); then
    error "'$DEVEL_BRANCH' is behind '${MAIN_REMOTE}/${DEVEL_BRANCH}' by $behind commit(s). Pull before releasing."
  fi
  if (( ahead > 0 )); then
    error "'$DEVEL_BRANCH' has $ahead unpushed commit(s). Push before releasing."
  fi
fi

# Run verification before merging
info "Running verification (typecheck + lint + test + build)..."
npm run typecheck
npm run lint
npm test
npm run build

# Perform the merge
info "Checking out '$MAIN_BRANCH'..."
git checkout "$MAIN_BRANCH"
git pull "$MAIN_REMOTE" "$MAIN_BRANCH"

info "Merging '$DEVEL_BRANCH' into '$MAIN_BRANCH'..."
git merge "$DEVEL_BRANCH" --ff-only

info "Pushing '$MAIN_BRANCH' to '$MAIN_REMOTE'..."
git push "$MAIN_REMOTE" "$MAIN_BRANCH"

# Return to devel
git checkout "$DEVEL_BRANCH"

success "Released. CI will deploy to production and create a GitHub release."
